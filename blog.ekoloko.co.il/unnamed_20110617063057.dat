		<link>http://blog.ekoloko.co.il/?p=4607&amp;utm_source=rss&amp;utm_medium=rss&amp;utm_campaign=%25d7%2594%25d7%25a1%25d7%2599%25d7%2599%25d7%25a8%25d7%25aa-%25d7%2594%25d7%25a9%25d7%2591%25d7%2595%25d7%25a2%25d7%2599%25d7%25aa-%25d7%2594%25d7%259e%25d7%25a6%25d7%2598%25d7%2599%25d7%2599%25d7%25a0%25d7%25aa-295-linoi14</link>
