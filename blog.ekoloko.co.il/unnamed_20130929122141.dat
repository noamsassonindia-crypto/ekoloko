		<pubDate>Wed, 29 Dec 2010 07:03:45 +0000</pubDate>
		<dc:creator>admin</dc:creator>
				<category><![CDATA[הכירו את... (ראיונות)]]></category>

		<guid isPermaLink="false">http://blog.ekoloko.co.il/?p=3244</guid>
		<description><![CDATA[
