		<link>http://blog.ekoloko.co.il/?p=2557&amp;utm_source=rss&amp;utm_medium=rss&amp;utm_campaign=%25d7%2594%25d7%259b%25d7%2599%25d7%25a8%25d7%2595-%25d7%2590%25d7%25aa-%25d7%2594%25d7%259e%25d7%25a0%25d7%2594%25d7%259c%25d7%2599%25d7%259d-minimi</link>
