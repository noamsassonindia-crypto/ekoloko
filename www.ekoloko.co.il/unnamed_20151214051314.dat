		<title>שעת כדור הארץ</title>
		<link>http://blog.ekoloko.co.il/?p=5074&amp;utm_source=rss&amp;utm_medium=rss&amp;utm_campaign=%25d7%25a9%25d7%25a2%25d7%25aa-%25d7%259b%25d7%2593%25d7%2595%25d7%25a8-%25d7%2594%25d7%2590%25d7%25a8%25d7%25a5</link>
		<comments>http://blog.ekoloko.co.il/?p=5074#comments</comments>
		<pubDate>Sun, 22 Apr 2012 10:10:51 +0000</pubDate>
		<dc:creator>admin</dc:creator>
